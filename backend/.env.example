APP_NAME=Pic2Ads API
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/v1
DATABASE_URL=
SUPABASE_DB_URL=
SUPABASE_POOLER_URL=
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=pic2ads-main
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_CREATE_TASK_PATH=/api/v1/jobs/createTask
KIE_TASK_DETAIL_PATH=/api/v1/jobs/getTaskDetail
KIE_DEFAULT_MODEL=bytedance/seedance-2
KIE_CALLBACK_URL=
KIE_WEBHOOK_SECRET=
KIE_MAX_RETRIES=3
KIE_RETRY_BASE_DELAY_SECONDS=30
KIE_RETRY_WORKER_ENABLED=false
KIE_RETRY_WORKER_INTERVAL_SECONDS=20
KIE_RETRY_WORKER_BATCH_SIZE=10
